# Copy to .env and fill in. Only ANTHROPIC_API_KEY is required for the agentic
# features; without it the orchestrator runs in a deterministic stub mode.

ANTHROPIC_API_KEY=
# Optional: use a faster/cheaper model for the live demo.
# CLAUDE_MODEL=claude-sonnet-4-6

# Platform URLs (defaults match docker-compose host ports).
NEXTXR_URL=http://localhost:8000
AUTOMIND_URL=http://localhost:8001
GOALCERT_URL=http://localhost:8002

# AUTOMIND login (seed demo user; the orchestrator self-registers if needed).
AUTOMIND_EMAIL=prem@goalcert.com
AUTOMIND_PASSWORD=demo1234

ORCHESTRATOR_PORT=8090
