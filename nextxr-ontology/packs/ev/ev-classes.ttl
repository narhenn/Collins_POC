@prefix ev:   <https://ontology.nextxr.io/v3/ev#> .
@prefix nxr:  <https://ontology.nextxr.io/v3/core#> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix unit: <http://qudt.org/vocab/unit/> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:  <http://purl.org/dc/terms/> .

#################################################################
#  EV / E-MOBILITY DOMAIN PACK v1.0  —  LAYER 4
#
#  Electric-vehicle charging + energy vertical: the charging network
#  (stations, chargers, connectors, grid connection, transformer,
#  solar, BESS, V2G) and the battery domain (packs, modules, cells)
#  with electric-vehicle and fleet twins. This is the full semantic
#  backbone; the physics, behaviour rules and live views live in
#  nextxr-ontology/ev/ (EVPhysics) + behaviors/ev/, and are surfaced
#  by the GoalCert Workforce Intelligence energy-site twin.
#
#  Stack: BFO -> SOSA -> platform (nxr) -> EV
#################################################################

<https://ontology.nextxr.io/v3/ev> a owl:Ontology ;
    dct:title "NextXR EV / E-Mobility Pack" ;
    owl:versionInfo "1.0.0" ;
    dct:description "Electric-vehicle charging network + battery domain: charging stations, chargers, connectors, grid connection, transformer, solar generation, BESS, V2G, battery packs/modules/cells, electric vehicles and fleets, each with dedicated physics and safety monitoring. Surfaced by the GoalCert Workforce Intelligence energy-site twin." ;
    owl:imports <https://ontology.nextxr.io/v3/core> .


#################################################################
#  TWIN HEADS  (twinned as a single asset)
#################################################################
ev:ChargingNetwork a owl:Class ;
    rdfs:subClassOf nxr:Equipment ;
    rdfs:label "Charging Network" ;
    skos:definition "An EV charging network twinned as a single supervised asset with a live map: charging stations, chargers, grid connection, transformer, solar generation, BESS and V2G, monitored via network KPIs and per-station status." ;
    nxr:taxonomyCategory "PhysicalAsset" .

ev:BatteryPack a owl:Class ;
    rdfs:subClassOf nxr:Equipment ;
    rdfs:label "Battery Pack" ;
    skos:definition "A traction/storage battery pack twinned at cell level: modules of cells with a Thevenin ECM, thermal coupling and degradation model, monitored for imbalance, thermal runaway precursors and state-of-health." ;
    nxr:taxonomyCategory "PhysicalAsset" .


#################################################################
#  CHARGING INFRASTRUCTURE  (⊑ nxr:Equipment)
#################################################################
ev:ChargingStation a owl:Class ;
    rdfs:subClassOf nxr:Equipment ;
    rdfs:label "Charging Station" ;
    skos:definition "A physical charging site hosting one or more chargers, drawing from a grid connection and optionally local solar + BESS." ;
    nxr:taxonomyCategory "PhysicalAsset" .

ev:Charger a owl:Class ;
    rdfs:subClassOf nxr:Equipment ;
    rdfs:label "Charger" ;
    skos:definition "An EVSE / charge point delivering DC or AC power to a vehicle, with OCPP setpoint feedback and power derating under connector heat or grid weakness." ;
    nxr:taxonomyCategory "PhysicalAsset" .

ev:Connector a owl:Class ;
    rdfs:subClassOf nxr:Equipment ;
    rdfs:label "Connector" ;
    skos:definition "A charging connector (CCS/CHAdeMO/Type 2) whose contact temperature bounds the deliverable current." ;
    nxr:taxonomyCategory "PhysicalAsset" .

ev:GridConnection a owl:Class ;
    rdfs:subClassOf nxr:Equipment ;
    rdfs:label "Grid Connection" ;
    skos:definition "The point of common coupling to the distribution grid, with a voltage/frequency and an import/export limit." ;
    nxr:taxonomyCategory "PhysicalAsset" .

ev:Transformer a owl:Class ;
    rdfs:subClassOf nxr:Equipment ;
    rdfs:label "Grid Transformer" ;
    skos:definition "A distribution transformer feeding the charging network, whose winding hot-spot temperature and insulation loss-of-life are tracked per IEC 60076-7." ;
    nxr:taxonomyCategory "PhysicalAsset" .

ev:SolarPanel a owl:Class ;
    rdfs:subClassOf nxr:Equipment ;
    rdfs:label "Solar Panel Array" ;
    skos:definition "A photovoltaic array generating power from irradiance, offsetting charging demand and exporting surplus." ;
    nxr:taxonomyCategory "PhysicalAsset" .

ev:BatteryStorage a owl:Class ;
    rdfs:subClassOf nxr:Equipment ;
    rdfs:label "Battery Energy Storage System" ;
    skos:definition "An on-site BESS that peak-shaves the grid transformer and soaks surplus solar, dispatched by the site EMS under a fixed grid limit." ;
    nxr:taxonomyCategory "PhysicalAsset" .

ev:EnergyManagementSystem a owl:Class ;
    rdfs:subClassOf nxr:Equipment ;
    rdfs:label "Energy Management System" ;
    skos:definition "The site EMS controller that fair-shares charging load, peak-shaves via the BESS and holds site draw under the transformer limit — the load-balancing brain of the energy site." ;
    nxr:taxonomyCategory "PhysicalAsset" .

ev:CoolingSystem a owl:Class ;
    rdfs:subClassOf nxr:Equipment ;
    rdfs:label "Cooling System" ;
    skos:definition "A liquid-cooling loop removing heat from a battery pack or DC fast charger, characterised by coolant inlet temperature and flow rate." ;
    nxr:taxonomyCategory "PhysicalAsset" .


#################################################################
#  BATTERY DOMAIN  (⊑ nxr:Equipment)
#################################################################
ev:BatteryModule a owl:Class ;
    rdfs:subClassOf nxr:Equipment ;
    rdfs:label "Battery Module" ;
    skos:definition "A series/parallel group of cells within a pack, the unit of thermal and balancing management." ;
    nxr:taxonomyCategory "PhysicalAsset" .

ev:BatteryCell a owl:Class ;
    rdfs:subClassOf nxr:Equipment ;
    rdfs:label "Battery Cell" ;
    skos:definition "An individual electrochemical cell with its own voltage, temperature, state-of-charge and state-of-health — the atom of the cell-level heatmap." ;
    nxr:taxonomyCategory "PhysicalAsset" .


#################################################################
#  VEHICLES / FLEET
#################################################################
ev:ElectricVehicle a owl:Class ;
    rdfs:subClassOf nxr:MobileAsset ;
    rdfs:label "Electric Vehicle" ;
    skos:definition "An electric vehicle with a battery pack and a PMSM drive, twinned for range prediction and V2G participation." ;
    nxr:taxonomyCategory "MobileAsset" .

ev:EVFleet a owl:Class ;
    rdfs:subClassOf nxr:Equipment ;
    rdfs:label "EV Fleet" ;
    skos:definition "A fleet of electric vehicles aggregated as a twin for charging scheduling, state-of-health tracking and V2G dispatch." ;
    nxr:taxonomyCategory "PhysicalAsset" .


#################################################################
#  OBSERVABLE PROPERTIES  (the live signals)
#
#  Two sets, both first-class:
#   (a) the live `ev:` channels the GoalCert energy-site twin emits
#       (ev/physics.py SIGNALS) — what the dashboard/3-D world render;
#   (b) the deeper battery/motor backbone signals (pack/cell/PMSM).
#################################################################

### (a) Charging management — OCPP (live twin) ###
ev:chargerUptime       a sosa:ObservableProperty ; rdfs:label "Charger Network Uptime" .
ev:utilization         a sosa:ObservableProperty ; rdfs:label "Charger Utilisation" .
ev:sessionsActive      a sosa:ObservableProperty ; rdfs:label "Active Sessions" .
ev:faultedChargers     a sosa:ObservableProperty ; rdfs:label "Faulted Chargers" .
ev:ocppLatency         a sosa:ObservableProperty ; rdfs:label "OCPP Heartbeat Latency" ; nxr:expectedUnit unit:MilliSEC .
ev:queueWait           a sosa:ObservableProperty ; rdfs:label "Queue Wait Time" ; nxr:expectedUnit unit:MIN .
ev:chargingPower       a sosa:ObservableProperty ; rdfs:label "Delivered Charging Power" ; nxr:expectedUnit unit:KiloW .

### (a) Energy management — EMS / grid (live twin) ###
ev:gridLoad            a sosa:ObservableProperty ; rdfs:label "Grid Load" .
ev:loadHeadroom        a sosa:ObservableProperty ; rdfs:label "Grid Load Headroom" .
ev:peakDemand          a sosa:ObservableProperty ; rdfs:label "Site Peak Demand" ; nxr:expectedUnit unit:KiloW .
ev:transformerTemp     a sosa:ObservableProperty ; rdfs:label "Transformer Temperature" ; nxr:expectedUnit unit:DEG_C .
ev:bessSoc             a sosa:ObservableProperty ; rdfs:label "BESS State of Charge" .
ev:bessPower           a sosa:ObservableProperty ; rdfs:label "BESS Power" ; nxr:expectedUnit unit:KiloW .
ev:solarOutput         a sosa:ObservableProperty ; rdfs:label "Solar Output" ; nxr:expectedUnit unit:KiloW .
ev:selfConsumption     a sosa:ObservableProperty ; rdfs:label "Solar Self-Consumption" .
ev:v2gCapacity         a sosa:ObservableProperty ; rdfs:label "V2G Available Capacity" ; nxr:expectedUnit unit:KiloW-HR .

### (a) Fleet & battery health (live twin) ###
ev:stateOfCharge       a sosa:ObservableProperty ; rdfs:label "State of Charge" .
ev:stateOfHealth       a sosa:ObservableProperty ; rdfs:label "State of Health" .
ev:cellTempMax         a sosa:ObservableProperty ; rdfs:label "Max Cell Temperature" ; nxr:expectedUnit unit:DEG_C .
ev:cellImbalance       a sosa:ObservableProperty ; rdfs:label "Cell Voltage Imbalance" ; nxr:expectedUnit unit:MilliV .
ev:coolantTemp         a sosa:ObservableProperty ; rdfs:label "Coolant Temperature" ; nxr:expectedUnit unit:DEG_C .
ev:insulationResistance a sosa:ObservableProperty ; rdfs:label "HV Insulation Resistance" ; nxr:expectedUnit unit:KiloOHM .
ev:thermalRunawayRisk  a sosa:ObservableProperty ; rdfs:label "Thermal Runaway Risk" .

### (a) Commercial (live twin) ###
ev:revenueToday        a sosa:ObservableProperty ; rdfs:label "Revenue Today" .
ev:tariffRate          a sosa:ObservableProperty ; rdfs:label "Dynamic Tariff Rate" .
ev:energyToday         a sosa:ObservableProperty ; rdfs:label "Energy Delivered Today" ; nxr:expectedUnit unit:MegaW-HR .
ev:co2Avoided          a sosa:ObservableProperty ; rdfs:label "CO2 Avoided" ; nxr:expectedUnit unit:KiloGM .

### (b) Deeper battery / motor backbone ###
ev:cellVoltageDelta    a sosa:ObservableProperty ; rdfs:label "Cell Voltage Delta" ; nxr:expectedUnit unit:V .
ev:packVoltage         a sosa:ObservableProperty ; rdfs:label "Pack Voltage" ; nxr:expectedUnit unit:V .
ev:packCurrent         a sosa:ObservableProperty ; rdfs:label "Pack Current" ; nxr:expectedUnit unit:A .
ev:cellTempRise        a sosa:ObservableProperty ; rdfs:label "Cell Temperature Rise Rate" .
ev:chargeRate          a sosa:ObservableProperty ; rdfs:label "Charge Rate (C)" .
ev:motorTemp           a sosa:ObservableProperty ; rdfs:label "Motor Winding Temperature" ; nxr:expectedUnit unit:DEG_C .
ev:motorEfficiency     a sosa:ObservableProperty ; rdfs:label "Motor Efficiency" .
ev:rangeEstimate       a sosa:ObservableProperty ; rdfs:label "Range Estimate" ; nxr:expectedUnit unit:KiloM .

### (b) Grid / transformer backbone ###
ev:gridVoltage         a sosa:ObservableProperty ; rdfs:label "Grid Voltage" .
ev:gridFrequency       a sosa:ObservableProperty ; rdfs:label "Grid Frequency" ; nxr:expectedUnit unit:HZ .
ev:transformerAging    a sosa:ObservableProperty ; rdfs:label "Transformer Aging Rate" .
ev:solarIrradiance     a sosa:ObservableProperty ; rdfs:label "Solar Irradiance" .


#################################################################
#  OBJECT PROPERTIES  (the EV entity-relationship spine)
#################################################################
ev:hasStation a owl:ObjectProperty ;
    rdfs:subPropertyOf nxr:hasPart ;
    rdfs:domain ev:ChargingNetwork ; rdfs:range ev:ChargingStation ;
    rdfs:label "has station" .

ev:hasCharger a owl:ObjectProperty ;
    rdfs:subPropertyOf nxr:hasPart ;
    rdfs:domain ev:ChargingStation ; rdfs:range ev:Charger ;
    rdfs:label "has charger" .

ev:hasConnector a owl:ObjectProperty ;
    rdfs:subPropertyOf nxr:hasPart ;
    rdfs:domain ev:Charger ; rdfs:range ev:Connector ;
    rdfs:label "has connector" .

ev:poweredBy a owl:ObjectProperty ;
    rdfs:subPropertyOf nxr:dependsOn ;
    rdfs:range ev:GridConnection ;
    rdfs:label "powered by" .

ev:feedsGrid a owl:ObjectProperty ;
    rdfs:subPropertyOf nxr:feeds ;
    rdfs:range ev:GridConnection ;
    rdfs:label "feeds grid" .

ev:managedBy a owl:ObjectProperty ;
    rdfs:subPropertyOf nxr:dependsOn ;
    rdfs:range ev:EnergyManagementSystem ;
    rdfs:label "managed by" .

ev:hasModule a owl:ObjectProperty ;
    rdfs:subPropertyOf nxr:hasPart ;
    rdfs:domain ev:BatteryPack ; rdfs:range ev:BatteryModule ;
    rdfs:label "has module" .

ev:hasCell a owl:ObjectProperty ;
    rdfs:subPropertyOf nxr:hasPart ;
    rdfs:domain ev:BatteryModule ; rdfs:range ev:BatteryCell ;
    rdfs:label "has cell" .

ev:hasVehicle a owl:ObjectProperty ;
    rdfs:subPropertyOf nxr:hasPart ;
    rdfs:domain ev:EVFleet ; rdfs:range ev:ElectricVehicle ;
    rdfs:label "has vehicle" .

ev:cools a owl:ObjectProperty ;
    rdfs:subPropertyOf nxr:feeds ;
    rdfs:domain ev:CoolingSystem ;
    rdfs:label "cools" .


#################################################################
#  DATATYPE PROPERTIES
#################################################################
ev:ratedPowerKW a owl:DatatypeProperty ;
    rdfs:label "rated power (kW)" ; rdfs:range xsd:double ;
    skos:definition "Rated power of a charger/transformer/inverter (kW)." .

ev:nominalVoltage a owl:DatatypeProperty ;
    rdfs:label "nominal voltage (V)" ; rdfs:range xsd:double .

ev:stateOfChargePct a owl:DatatypeProperty ;
    rdfs:label "state of charge (%)" ; rdfs:range xsd:double .

ev:stateOfHealthPct a owl:DatatypeProperty ;
    rdfs:label "state of health (%)" ; rdfs:range xsd:double .

ev:capacityKWh a owl:DatatypeProperty ;
    rdfs:label "energy capacity (kWh)" ; rdfs:range xsd:double ;
    skos:definition "Usable energy capacity of a battery pack or BESS (kWh)." .

ev:cellCount a owl:DatatypeProperty ;
    rdfs:label "cell count" ; rdfs:range xsd:integer .

ev:moduleCount a owl:DatatypeProperty ;
    rdfs:label "module count" ; rdfs:range xsd:integer .


#################################################################
#  FAILURE MODES
#################################################################
ev:CellImbalance a owl:Class ;
    rdfs:subClassOf nxr:FailureMode ;
    rdfs:label "Cell Voltage Imbalance" ;
    skos:definition "Max–min cell voltage delta exceeds the balancing threshold — capacity loss and hot-spotting risk." ;
    nxr:taxonomyCategory "Capability" .

ev:ThermalRunaway a owl:Class ;
    rdfs:subClassOf nxr:FailureMode ;
    rdfs:label "Thermal Runaway Precursor" ;
    skos:definition "Cell temperature rise rate and voltage collapse indicate the onset of thermal runaway — a P0 safety event." ;
    nxr:taxonomyCategory "Capability" .

ev:GridOverload a owl:Class ;
    rdfs:subClassOf nxr:FailureMode ;
    rdfs:label "Grid Overload" ;
    skos:definition "Total charging load approaches the transformer rated capacity — load shedding required to prevent a trip." ;
    nxr:taxonomyCategory "Capability" .

ev:TransformerOverheat a owl:Class ;
    rdfs:subClassOf nxr:FailureMode ;
    rdfs:label "Transformer Overheat" ;
    skos:definition "Transformer hot-spot temperature accelerates insulation loss-of-life beyond the IEC 60076-7 reference." ;
    nxr:taxonomyCategory "Capability" .

ev:BatteryEndOfLife a owl:Class ;
    rdfs:subClassOf nxr:FailureMode ;
    rdfs:label "Battery End-of-Life" ;
    skos:definition "State-of-health falls below the first-life threshold (80%), initiating a second-life assessment." ;
    nxr:taxonomyCategory "Capability" .

ev:ChargerFault a owl:Class ;
    rdfs:subClassOf nxr:FailureMode ;
    rdfs:label "Charger Fault" ;
    skos:definition "EVSE reports an OCPP fault / heartbeat loss — sessions drop and utilisation and revenue fall until reset or field service." ;
    nxr:taxonomyCategory "Capability" .

ev:InsulationFault a owl:Class ;
    rdfs:subClassOf nxr:FailureMode ;
    rdfs:label "HV Insulation Fault" ;
    skos:definition "High-voltage insulation resistance falls below the isolation limit — moisture or cable damage risking an isolation fault." ;
    nxr:taxonomyCategory "Capability" .

ev:HeadroomExhausted a owl:Class ;
    rdfs:subClassOf nxr:FailureMode ;
    rdfs:label "Grid Headroom Exhausted" ;
    skos:definition "Grid load headroom falls to the minimum — no capacity for new sessions; arrivals must queue and storage dispatch." ;
    nxr:taxonomyCategory "Capability" .
