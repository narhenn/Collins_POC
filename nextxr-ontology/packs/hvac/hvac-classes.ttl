@prefix hvac: <https://ontology.nextxr.io/v3/hvac#> .
@prefix cfp:  <https://ontology.nextxr.io/v3/cfp#> .
@prefix nxr:  <https://ontology.nextxr.io/v3/core#> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix unit: <http://qudt.org/vocab/unit/> .
@prefix quantitykind: <http://qudt.org/vocab/quantitykind/> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

#################################################################
#  HVAC CAPABILITY PACK  —  LAYER 4 (a domain extension)
#
#  This is the proof of the whole design: every class here is a
#  SUBCLASS of a CFP or platform mid-level class. It adds
#  vocabulary DOWNWARD and touches nothing in layers 1-3.5.
#
#  Extends: Common Facilities Pack (CFP) for HVAC-specific
#  equipment, the platform mid-level for everything else.
#################################################################

<https://ontology.nextxr.io/v3/hvac> a owl:Ontology ;
    owl:versionInfo "1.1.0" ;
    rdfs:label "HVAC Capability Pack" ;
    owl:imports <https://ontology.nextxr.io/v3/core> ,
                <https://ontology.nextxr.io/v3/cfp> .

### Equipment subclasses — now extend CFP universal classes ###
hvac:AirHandler a owl:Class ;
    rdfs:subClassOf cfp:AirHandlingUnit ;
    rdfs:label "HVAC Air Handler" ;
    skos:definition "An air handling unit within an HVAC system, conditioning and circulating air to served zones." ;
    nxr:taxonomyCategory "PhysicalAsset" .

hvac:Chiller a owl:Class ;
    rdfs:subClassOf cfp:Chiller ;
    rdfs:label "HVAC Chiller" ;
    skos:definition "A chiller within an HVAC system, removing heat from a liquid via a refrigeration cycle to supply chilled water to air handlers." ;
    nxr:taxonomyCategory "PhysicalAsset" .

### Sensor subclass — now extends CFP TemperatureSensor ###
hvac:TemperatureSensor a owl:Class ;
    rdfs:subClassOf cfp:TemperatureSensor ;
    rdfs:label "HVAC Temperature Sensor" ;
    skos:definition "A temperature sensor measuring air or water temperature within an HVAC system." ;
    nxr:taxonomyCategory "PhysicalAsset" .

hvac:AirTemperature a sosa:ObservableProperty ;
    rdfs:label "Air Temperature" ;
    nxr:expectedUnit unit:DEG_C ;
    nxr:expectedQuantityKind quantitykind:Temperature .

### A domain placement predicate — subproperty of the generic one ###
hvac:servesSpace a owl:ObjectProperty ;
    rdfs:subPropertyOf cfp:suppliesAirTo ;
    rdfs:label "serves space" ;
    skos:definition "An HVAC air handler conditions the air of a space. Subproperty of the CFP universal cfp:suppliesAirTo." ;
    rdfs:domain hvac:AirHandler ;
    rdfs:range nxr:Space .

### A domain failure mode ###
hvac:FilterClogged a owl:Class ;
    rdfs:subClassOf nxr:FailureMode ;
    rdfs:label "Filter Clogged" ;
    skos:definition "Airflow restriction caused by a saturated filter." ;
    nxr:taxonomyCategory "Capability" .

### A domain state machine, declared exactly like the platform's ###
hvac:AirHandlerStateMachine a nxr:StateMachine ;
    rdfs:label "Air handler lifecycle" ;
    nxr:initialState hvac:s_off ;
    nxr:hasState hvac:s_off , hvac:s_running , hvac:s_degraded , hvac:s_fault ;
    nxr:allowsTransition hvac:t_off_run , hvac:t_run_deg , hvac:t_deg_fault , hvac:t_fault_off .

hvac:s_off      a nxr:State ; rdfs:label "off" .
hvac:s_running  a nxr:State ; rdfs:label "running" .
hvac:s_degraded a nxr:State ; rdfs:label "degraded" .
hvac:s_fault    a nxr:State ; rdfs:label "fault" .

hvac:t_off_run    a nxr:Transition ; nxr:fromState hvac:s_off ;      nxr:toState hvac:s_running .
hvac:t_run_deg    a nxr:Transition ; nxr:fromState hvac:s_running ;  nxr:toState hvac:s_degraded .
hvac:t_deg_fault  a nxr:Transition ; nxr:fromState hvac:s_degraded ; nxr:toState hvac:s_fault .
hvac:t_fault_off  a nxr:Transition ; nxr:fromState hvac:s_fault ;    nxr:toState hvac:s_off .

hvac:AirHandler nxr:hasStateMachine hvac:AirHandlerStateMachine .
