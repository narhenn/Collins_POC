@prefix hvac: <https://ontology.nextxr.io/v3/hvac#> .
@prefix cfp:  <https://ontology.nextxr.io/v3/cfp#> .
@prefix nxr:  <https://ontology.nextxr.io/v3/core#> .
@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

#################################################################
#  HVAC PACK SHAPES — inherit BaseEntityShape, add HVAC rules
#
#  hvac:AirHandler now extends cfp:AirHandlingUnit. The HVAC shape
#  still enforces hvac:servesSpace (which is a subPropertyOf
#  cfp:suppliesAirTo). Existing code using hvac:servesSpace CURIEs
#  continues to work unmodified.
#################################################################

hvac:AirHandlerShape a sh:NodeShape ;
    sh:targetClass hvac:AirHandler ;
    sh:node nxr:BaseEntityShape ;
    sh:property [
        sh:path hvac:servesSpace ;
        sh:minCount 1 ;
        sh:message "An HVAC air handler must serve at least one space." ;
    ] .

hvac:TemperatureSensorShape a sh:NodeShape ;
    sh:targetClass hvac:TemperatureSensor ;
    sh:node nxr:BaseEntityShape ;
    sh:property [
        sh:path nxr:monitors ;
        sh:minCount 1 ;
        sh:message "A temperature sensor must monitor a feature of interest." ;
    ] .
